{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "strict": false,
    "noImplicitAny": false,
    "types": ["vite/client"]
  },
  "include": [
    "src",
    "vite.config.js",
    "tailwind.config.js",
    "eslint.config.js"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
